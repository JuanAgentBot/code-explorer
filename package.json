{
  "name": "@juanagentbot/code-explorer",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "bin": {
    "code-explorer": "dist/cli.mjs"
  },
  "files": [
    "dist/"
  ],
  "scripts": {
    "dev": "vite",
    "build": "npm run build:web && npm run build:cli",
    "build:web": "vite build",
    "build:cli": "esbuild src/cli/index.ts --bundle --platform=node --target=node18 --format=esm --banner:js='#!/usr/bin/env node' --outfile=dist/cli.mjs --packages=external",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test": "vitest run",
    "check": "npm run typecheck && npm run lint && npm run test"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/lz-string": "^1.3.34",
    "@types/node": "^25.5.0",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "typescript-eslint": "^8.57.2",
    "vite": "^6.3.5",
    "vitest": "^4.1.1"
  },
  "dependencies": {
    "@codemirror/lang-javascript": "^6.2.5",
    "@codemirror/theme-one-dark": "^6.1.3",
    "codemirror": "^6.0.2",
    "lz-string": "^1.5.0",
    "typescript": "^5.8.3"
  }
}
